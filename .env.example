# ── Required ────────────────────────────────────────────────────────────────
# Password for logging into the web UI (single shared password, minimum 12 chars).
# The app refuses to start until this example value is replaced.
FRONTEND_PASSWORD=change-me

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
# The app refuses to start until this public example value is replaced.
AUTH_SECRET=please-generate-a-random-secret-at-least-32-chars

# ── Backend ─────────────────────────────────────────────────────────────────
# URL of the riven-ts GraphQL endpoint (Apollo Server root path)
BACKEND_GRAPHQL_URL=http://localhost:3000/

# ── Optional ────────────────────────────────────────────────────────────────
# Read-only connection to riven-ts's Postgres. Enables full-library search,
# filtering and pagination (the GraphQL mediaItems query is capped at 25 items
# and is currently broken upstream anyway).
# RIVEN_DATABASE_URL=postgresql://riven:password@riven-postgres:5432/riven

# TMDB API Read Access Token (v4 bearer token) — enables search, trending,
# posters and the request flow. Get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=

# Required in production (adapter-node): the HTTPS public URL the app is served on.
# Form submissions fail with 403 if this is wrong.
ORIGIN=http://localhost:3001

# For the default (frontend-only) docker-compose.yaml: the docker network your
# existing riven-ts container runs on. Find it with:
#   docker inspect riven --format '{{range $k,$v := .NetworkSettings.Networks}}{{println $k}}{{end}}'
# RIVEN_NETWORK=riven_default
# Container names used by the isolated management helper for the Settings page actions.
RIVEN_CONTAINER_NAME=riven
RIVEN_REDIS_CONTAINER_NAME=riven-redis
